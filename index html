<script>
// ── SUPABASE INIT
var SUPABASE_URL='https://cbmelgsiahzevifcnetz.supabase.co';
var SUPABASE_ANON_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNibWVsZ3NpYWh6ZXZpZmNuZXR6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE3NTk1MTksImV4cCI6MjA4NzMzNTUxOX0.rD2aWQvNpq4wiKxesf3KwC3bWLs_hpifwVlVMDmK7h0';
var sb=window.supabase.createClient(SUPABASE_URL,SUPABASE_ANON_KEY);
var FALLBACK=2314;

// ── CURSOR
const cur=document.getElementById('cur'), ring=document.getElementById('ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px'});
function animRing(){rx+=(mx-rx)*0.12;ry+=(my-ry)*0.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(animRing)}
animRing();
document.querySelectorAll('a,button,input,.faq-q,.listing-card,.feat-card,.hiw-card,.testi-card').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.style.width='16px';cur.style.height='16px';ring.style.width='56px';ring.style.height='56px'});
  el.addEventListener('mouseleave',()=>{cur.style.width='10px';cur.style.height='10px';ring.style.width='36px';ring.style.height='36px'});
});

// ── NAV SCROLL
window.addEventListener('scroll',()=>{
  document.getElementById('nav').classList.toggle('scrolled',scrollY>20);
});

// ── MOBILE MENU
function toggleMenu(){document.getElementById('mob-menu').classList.toggle('open')}

// ── SCROLL REVEAL
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')});
},{threshold:0.1});
document.querySelectorAll('.reveal,.reveal-left,.reveal-right').forEach(el=>obs.observe(el));

// ── WAITLIST COUNT
let count=FALLBACK;
const countEls=()=>[
  document.getElementById('live-count'),
  document.getElementById('proof-count'),
  document.getElementById('stat-count'),
  document.getElementById('cta-count')
].filter(Boolean);

function updateCount(n){
  count=n;
  countEls().forEach(el=>{if(el)el.textContent=n.toLocaleString()});
}

// Load real count from Supabase
(async function(){
  try{
    var r=await sb.from('waitlist').select('*',{count:'exact',head:true});
    if(!r.error && r.count>0) updateCount(r.count);
    else updateCount(FALLBACK);
  }catch(e){
    console.warn('Count fetch failed:',e);
    updateCount(FALLBACK);
  }
})();

// ── EMAIL SUBMISSION (Supabase)
const submitted=new Set();
async function submitEmail(form){
  var email=document.getElementById(form+'-email');
  var btn=document.getElementById(form+'-btn');
  var val=email.value.trim().toLowerCase();
  var valid=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);

  if(!valid){
    btn.classList.add('error');
    email.style.color='#EF4444';
    setTimeout(()=>{btn.classList.remove('error');email.style.color=''},500);
    return;
  }
  if(submitted.has(form)){return}
  submitted.add(form);

  var origText=btn.textContent;
  btn.textContent='Joining...';
  btn.style.opacity='0.7';
  btn.style.pointerEvents='none';

  try{
    var r=await sb.from('waitlist').insert([{email:val,source:form==='hero'?'hero_form':'cta_form'}]).select();

    if(r.error){
      if(r.error.code==='23505'||(r.error.message&&r.error.message.indexOf('duplicate')!==-1)){
        btn.textContent='✨ You\'re already on the list!';
        btn.classList.add('success');
        email.value='';
        email.placeholder='You\'re all set!';
        btn.style.opacity='1';
        btn.style.pointerEvents='auto';
        showToast('✨ You\'re already on the waitlist!');
        return;
      }
      throw r.error;
    }

    btn.textContent='🎉 You\'re on the list!';
    btn.classList.add('success');
    email.value='';
    email.placeholder='See you on launch day!';
    count++;
    updateCount(count);
    countEls().forEach(el=>{
      if(!el)return;
      el.style.transform='scale(1.15)';
      el.style.color='#10B981';
      el.style.transition='all 0.3s';
      setTimeout(()=>{el.style.transform='scale(1)';el.style.color=''},600);
    });
    showToast('🎉 You\'re on the waitlist! We\'ll be in touch soon.');
  }catch(e){
    console.error('Signup error:',e);
    btn.textContent=origText;
    btn.style.opacity='1';
    btn.style.pointerEvents='auto';
    submitted.delete(form);
    btn.classList.add('error');
    setTimeout(()=>btn.classList.remove('error'),500);
    showToast('Something went wrong — please try again.');
  }

  btn.style.opacity='1';
  btn.style.pointerEvents='auto';
}

function showToast(msg){
  var t=document.createElement('div');
  var isErr=msg.indexOf('went wrong')!==-1;
  t.style.cssText='position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(20px);background:'+(isErr?'#EF4444':'#10B981')+';color:white;padding:14px 24px;border-radius:100px;font-size:14px;font-weight:600;z-index:9999;font-family:var(--font-ui);box-shadow:0 8px 30px '+(isErr?'rgba(239,68,68,0.4)':'rgba(16,185,129,0.4)')+';transition:all 0.4s ease;opacity:0;white-space:nowrap;';
  t.textContent=msg;
  document.body.appendChild(t);
  requestAnimationFrame(()=>{t.style.opacity='1';t.style.transform='translateX(-50%) translateY(0)'});
  setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(-50%) translateY(20px)';setTimeout(()=>t.remove(),400)},4000);
}

// ── FAQ
function toggleFaq(el){
  const item=el.closest('.faq-item');
  const isOpen=item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
  if(!isOpen)item.classList.add('open');
}

// ── ANIMATED TRACKER (cycles through states)
const steps=document.querySelectorAll('.t-step');
let activeStep=2;

function advanceTracker(){
  if(activeStep>=steps.length-1){
    setTimeout(()=>{
      steps.forEach((s,i)=>{
        s.classList.remove('done','active');
        s.querySelector('.t-dot').textContent=i===0?'✓':'';
        s.querySelector('.t-name').textContent=['Application Submitted','Documents Verified','Under Review','Approval Decision','Lease Sent'][i];
        s.querySelector('.t-when').textContent=['March 12, 9:32 AM','March 12, 2:15 PM','In progress · usually 1–2 days','Pending','Pending'][i];
        const badge=s.querySelector('.t-badge');
        badge.className='t-badge badge-pending';badge.textContent='Pending';
      });
      steps[0].classList.add('done');
      steps[0].querySelector('.t-dot').textContent='✓';
      steps[0].querySelector('.t-badge').className='t-badge badge-done';steps[0].querySelector('.t-badge').textContent='Done';
      activeStep=0;
      setTimeout(advanceTracker,2000);
    },3000);
    return;
  }
  setTimeout(()=>{
    activeStep++;
    steps[activeStep-1].classList.remove('active');
    steps[activeStep-1].classList.add('done');
    steps[activeStep-1].querySelector('.t-dot').textContent='✓';
    steps[activeStep-1].querySelector('.t-badge').className='t-badge badge-done';
    steps[activeStep-1].querySelector('.t-badge').textContent='Done';
    steps[activeStep].classList.add('active');
    steps[activeStep].querySelector('.t-dot').textContent='●';
    steps[activeStep].querySelector('.t-badge').className='t-badge badge-active';
    steps[activeStep].querySelector('.t-badge').textContent='Active';
    if(activeStep===3){
      steps[activeStep].querySelector('.t-name').textContent='Approved ✓';
      steps[activeStep].querySelector('.t-when').textContent='Just now';
    }
    if(activeStep===4){
      steps[activeStep].querySelector('.t-name').textContent='Lease Sent 🎉';
      steps[activeStep].querySelector('.t-when').textContent='Sign within 48 hours';
    }
    advanceTracker();
  },3500);
}
setTimeout(advanceTracker,2000);

// ── ENTER KEY on forms
document.getElementById('hero-email').addEventListener('keydown',e=>{if(e.key==='Enter')submitEmail('hero')});
document.getElementById('cta-email').addEventListener('keydown',e=>{if(e.key==='Enter')submitEmail('cta')});
</script>
