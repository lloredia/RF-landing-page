<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>RentFlow — Search. Apply. Get Approved.</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#3B63F7;
  --blue-hover:#2b50e0;
  --blue-glow:rgba(59,99,247,0.35);
  --navy:#1a2560;
  --bg:#06080F;
  --bg2:#0C0F1A;
  --surface:rgba(255,255,255,0.04);
  --border:rgba(255,255,255,0.08);
  --border-light:rgba(255,255,255,0.12);
  --text:#F0F2FF;
  --text-muted:#8892B0;
  --text-dim:#4A5568;
  --white:#FFFFFF;
  --green:#10B981;
  --amber:#F59E0B;
  --red:#EF4444;
  --font-display:'Instrument Serif',Georgia,serif;
  --font-ui:'Outfit',sans-serif;
  --r:20px;
  --r-sm:12px;
  --r-xs:8px;
}
html{scroll-behavior:smooth}
body{
  font-family:var(--font-ui);
  background:var(--bg);
  color:var(--text);
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
  cursor:default;
}

/* ── CUSTOM CURSOR ── */
.cursor{
  position:fixed;width:10px;height:10px;
  background:var(--blue);border-radius:50%;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  transition:transform 0.1s,width 0.2s,height 0.2s,opacity 0.2s;
  mix-blend-mode:screen;
}
.cursor-ring{
  position:fixed;width:36px;height:36px;
  border:1.5px solid rgba(59,99,247,0.4);border-radius:50%;
  pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
  transition:transform 0.15s ease-out,width 0.3s,height 0.3s;
}

/* ── NOISE OVERLAY ── */
body::before{
  content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  opacity:0.4;
}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  display:flex;align-items:center;justify-content:space-between;
  padding:18px clamp(20px,5%,80px);
  background:rgba(6,8,15,0.7);
  backdrop-filter:blur(20px) saturate(180%);
  border-bottom:1px solid var(--border);
  transition:all 0.3s;
}
nav.scrolled{
  background:rgba(6,8,15,0.92);
  border-bottom-color:var(--border-light);
}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.logo-text{
  font-family:var(--font-ui);font-weight:800;font-size:20px;
  color:var(--white);letter-spacing:-0.5px;
}
.logo-text span{color:var(--blue)}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-links a{
  font-size:14px;font-weight:500;color:var(--text-muted);
  text-decoration:none;transition:color 0.2s;letter-spacing:0.01em;
}
.nav-links a:hover{color:var(--white)}
.nav-pill{
  background:var(--blue);color:white;border:none;
  padding:9px 20px;border-radius:100px;
  font-size:13px;font-weight:600;cursor:pointer;
  font-family:var(--font-ui);text-decoration:none;
  transition:all 0.2s;display:inline-flex;align-items:center;gap:6px;
  box-shadow:0 0 20px var(--blue-glow);
}
.nav-pill:hover{background:var(--blue-hover);box-shadow:0 0 30px var(--blue-glow);transform:translateY(-1px)}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px}
.hamburger span{display:block;width:22px;height:2px;background:var(--text-muted);border-radius:2px;transition:all 0.3s}
.mobile-menu{
  display:none;position:fixed;top:65px;left:0;right:0;
  background:rgba(6,8,15,0.97);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  padding:20px clamp(20px,5%,80px);
  flex-direction:column;gap:20px;z-index:499;
}
.mobile-menu.open{display:flex}
.mobile-menu a{font-size:16px;font-weight:500;color:var(--text-muted);text-decoration:none;padding:8px 0;border-bottom:1px solid var(--border)}
.mobile-menu a:last-child{border:none}

/* ── HERO ── */
.hero{
  min-height:100vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  text-align:center;padding:140px clamp(20px,5%,80px) 80px;
  position:relative;overflow:hidden;
}

/* Animated gradient orbs */
.orb{
  position:absolute;border-radius:50%;
  filter:blur(80px);pointer-events:none;
  animation:orb-float 8s ease-in-out infinite;
}
.orb1{
  width:600px;height:600px;
  background:radial-gradient(circle, rgba(59,99,247,0.18) 0%, transparent 70%);
  top:-100px;left:50%;transform:translateX(-50%);
  animation-delay:0s;
}
.orb2{
  width:400px;height:400px;
  background:radial-gradient(circle, rgba(99,59,247,0.12) 0%, transparent 70%);
  top:200px;left:-100px;
  animation-delay:-3s;
}
.orb3{
  width:350px;height:350px;
  background:radial-gradient(circle, rgba(59,180,247,0.1) 0%, transparent 70%);
  top:100px;right:-80px;
  animation-delay:-5s;
}
@keyframes orb-float{
  0%,100%{transform:translateY(0) translateX(-50%)}
  50%{transform:translateY(-40px) translateX(-50%)}
}
.orb2{animation:orb-float2 9s ease-in-out infinite}
.orb3{animation:orb-float3 7s ease-in-out infinite}
@keyframes orb-float2{0%,100%{transform:translateY(0)}50%{transform:translateY(-30px)}}
@keyframes orb-float3{0%,100%{transform:translateY(0)}50%{transform:translateY(25px)}}

/* Grid lines */
.hero-grid{
  position:absolute;inset:0;pointer-events:none;
  background-image:
    linear-gradient(rgba(59,99,247,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(59,99,247,0.05) 1px, transparent 1px);
  background-size:80px 80px;
  mask-image:radial-gradient(ellipse 80% 80% at 50% 0%, black 30%, transparent 75%);
}

.hero-content{position:relative;z-index:2;max-width:900px}

.badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(59,99,247,0.1);
  border:1px solid rgba(59,99,247,0.25);
  color:#7B9FF9;border-radius:100px;
  padding:6px 16px 6px 8px;font-size:13px;font-weight:500;
  margin-bottom:32px;
  animation:fade-up 0.7s ease both;
}
.badge-dot{
  width:24px;height:24px;border-radius:50%;
  background:var(--blue);display:flex;align-items:center;
  justify-content:center;font-size:11px;
  box-shadow:0 0 10px var(--blue-glow);
  animation:pulse-glow 2.5s ease-in-out infinite;
}
@keyframes pulse-glow{
  0%,100%{box-shadow:0 0 8px var(--blue-glow)}
  50%{box-shadow:0 0 20px var(--blue-glow)}
}

h1.hero-title{
  font-family:var(--font-display);
  font-size:clamp(48px,8vw,90px);
  font-weight:400;line-height:1.05;
  letter-spacing:-1px;
  color:var(--white);margin-bottom:28px;
  animation:fade-up 0.7s 0.1s ease both;
}
h1.hero-title em{
  font-style:italic;
  background:linear-gradient(135deg, #5B83FF 0%, #3B63F7 50%, #7B9FF9 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
h1.hero-title .serif-light{
  font-weight:300;
}

.hero-sub{
  font-size:clamp(16px,2vw,19px);color:var(--text-muted);
  max-width:520px;margin:0 auto 44px;
  line-height:1.7;font-weight:400;
  animation:fade-up 0.7s 0.2s ease both;
}

/* Email form */
.email-form{
  display:flex;align-items:center;
  background:rgba(255,255,255,0.04);
  border:1px solid var(--border-light);
  border-radius:100px;
  padding:6px 6px 6px 24px;
  max-width:460px;width:100%;margin:0 auto;
  box-shadow:0 0 40px rgba(59,99,247,0.1), inset 0 1px 0 rgba(255,255,255,0.05);
  animation:fade-up 0.7s 0.3s ease both;
  transition:border-color 0.3s, box-shadow 0.3s;
}
.email-form:focus-within{
  border-color:rgba(59,99,247,0.5);
  box-shadow:0 0 40px rgba(59,99,247,0.2), 0 0 0 4px rgba(59,99,247,0.06);
}
.email-form input{
  flex:1;background:transparent;border:none;outline:none;
  color:var(--white);font-size:15px;font-family:var(--font-ui);
  min-width:0;
}
.email-form input::placeholder{color:var(--text-dim)}
.email-form button{
  background:var(--blue);color:white;border:none;
  border-radius:100px;padding:12px 22px;
  font-size:14px;font-weight:600;font-family:var(--font-ui);
  cursor:pointer;white-space:nowrap;
  transition:all 0.2s;
  box-shadow:0 4px 16px rgba(59,99,247,0.4);
}
.email-form button:hover{background:var(--blue-hover);box-shadow:0 6px 24px rgba(59,99,247,0.5)}
.email-form button.success{background:var(--green);box-shadow:0 4px 16px rgba(16,185,129,0.4)}
.email-form button.error{animation:shake 0.4s ease}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}

.social-proof{
  display:flex;align-items:center;justify-content:center;gap:14px;
  margin-top:22px;
  animation:fade-up 0.7s 0.4s ease both;
}
.avatars{display:flex}
.av{
  width:30px;height:30px;border-radius:50%;
  border:2px solid var(--bg);margin-left:-8px;
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:700;color:white;
}
.av:first-child{margin-left:0}
.proof-text{font-size:13px;color:var(--text-muted)}
.proof-text strong{color:var(--white)}

/* ── APP PREVIEW ── */
.hero-preview{
  position:relative;z-index:2;
  width:100%;max-width:960px;
  margin-top:72px;
  animation:fade-up 0.9s 0.5s ease both;
}
.preview-glow{
  position:absolute;top:-40px;left:50%;transform:translateX(-50%);
  width:80%;height:60px;
  background:radial-gradient(ellipse, rgba(59,99,247,0.3) 0%, transparent 70%);
  filter:blur(20px);pointer-events:none;
}
.app-window{
  background:#0E1219;
  border:1px solid var(--border-light);
  border-radius:18px;
  overflow:hidden;
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.03),
    0 40px 100px rgba(0,0,0,0.6),
    0 0 60px rgba(59,99,247,0.08);
}
.win-bar{
  background:#131820;border-bottom:1px solid var(--border);
  padding:13px 18px;display:flex;align-items:center;gap:10px;
}
.win-dot{width:11px;height:11px;border-radius:50%}
.win-dot.r{background:#FF5F56}.win-dot.y{background:#FFBD2E}.win-dot.g{background:#27C93F}
.win-url{
  margin-left:14px;flex:1;background:rgba(255,255,255,0.05);
  border:1px solid var(--border);border-radius:8px;
  padding:5px 14px;font-size:12px;color:var(--text-dim);
  max-width:260px;display:flex;align-items:center;gap:6px;
}
.win-url::before{content:'🔒';font-size:10px}
.win-body{display:grid;grid-template-columns:240px 1fr;min-height:360px}
.win-sidebar{
  background:#0A0D13;border-right:1px solid var(--border);
  padding:20px 16px;display:flex;flex-direction:column;gap:6px;
}
.sidebar-label{font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-dim);padding:0 10px;margin-bottom:4px;margin-top:12px}
.sidebar-label:first-child{margin-top:0}
.sidebar-item{
  display:flex;align-items:center;gap:10px;
  padding:8px 10px;border-radius:var(--r-xs);
  font-size:13px;color:var(--text-muted);cursor:pointer;
  transition:all 0.15s;
}
.sidebar-item:hover{background:var(--surface);color:var(--white)}
.sidebar-item.active{background:rgba(59,99,247,0.15);color:var(--blue)}
.sidebar-item .icon{width:18px;text-align:center;font-size:14px}
.win-main{padding:20px}
.win-search{
  display:flex;gap:8px;margin-bottom:18px;
}
.win-search-input{
  flex:1;background:rgba(255,255,255,0.04);
  border:1px solid var(--border);border-radius:var(--r-xs);
  padding:9px 14px;font-size:13px;color:var(--text-muted);
  display:flex;align-items:center;gap:8px;
}
.win-search-btn{
  background:var(--blue);border-radius:var(--r-xs);
  padding:9px 16px;font-size:13px;font-weight:600;color:white;
}
.listing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.listing-card{
  background:rgba(255,255,255,0.03);border:1px solid var(--border);
  border-radius:var(--r-sm);overflow:hidden;
  transition:all 0.2s;cursor:pointer;
}
.listing-card:hover{border-color:rgba(59,99,247,0.4);transform:translateY(-2px)}
.card-thumb{
  height:80px;display:flex;align-items:center;justify-content:center;
  font-size:26px;position:relative;overflow:hidden;
}
.ct1{background:linear-gradient(135deg,#1e3a8a22,#3b82f622)}
.ct2{background:linear-gradient(135deg,#4c1d9522,#7c3aed22)}
.ct3{background:linear-gradient(135deg,#14532d22,#16a34a22)}
.card-approved{
  position:absolute;top:8px;right:8px;
  background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.3);
  color:#10B981;font-size:10px;font-weight:600;
  padding:2px 7px;border-radius:100px;
}
.card-info{padding:10px 11px}
.card-price{font-size:14px;font-weight:700;color:var(--white)}
.card-addr{font-size:11px;color:var(--text-dim);margin-top:2px}
.card-chips{display:flex;gap:4px;margin-top:7px;flex-wrap:wrap}
.chip{
  background:rgba(59,99,247,0.12);color:#7B9FF9;
  font-size:10px;font-weight:600;padding:2px 7px;border-radius:100px;
}
.card-btn{
  display:block;margin-top:8px;background:var(--blue);
  color:white;text-align:center;border-radius:6px;
  padding:6px;font-size:12px;font-weight:600;
  cursor:pointer;transition:background 0.2s;
}
.card-btn:hover{background:var(--blue-hover)}

/* ── TRUST STRIP ── */
.trust-strip{
  border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  padding:32px clamp(20px,5%,80px);
  display:flex;align-items:center;justify-content:center;flex-direction:column;gap:20px;
}
.trust-label{font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-dim)}
.trust-logos{display:flex;align-items:center;gap:clamp(24px,4vw,60px);flex-wrap:wrap;justify-content:center}
.trust-city{
  font-family:var(--font-ui);font-weight:700;font-size:16px;
  color:var(--text-dim);letter-spacing:-0.3px;
  transition:color 0.2s;cursor:default;
}
.trust-city:hover{color:var(--text-muted)}

/* ── SECTIONS COMMON ── */
section.light{
  background:#FAFAFA;color:#0F1117;
}
.container{max-width:1120px;margin:0 auto;padding:0 clamp(20px,5%,80px)}
.section-pad{padding:100px 0}

.tag{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(59,99,247,0.08);color:var(--blue);
  border:1px solid rgba(59,99,247,0.2);
  border-radius:100px;padding:4px 14px;
  font-size:12px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;
  margin-bottom:18px;
}
.tag.light-tag{background:#EEF2FF;color:#3B63F7;border-color:#C7D4FE}

.s-title{
  font-family:var(--font-display);
  font-size:clamp(34px,4.5vw,58px);
  font-weight:400;letter-spacing:-1px;line-height:1.1;
  margin-bottom:16px;
}
.s-title em{font-style:italic;color:var(--blue)}
.s-title.light-title{color:#0F1117}
.s-sub{font-size:17px;color:var(--text-muted);line-height:1.7;max-width:480px}
.s-sub.light-sub{color:#6B7280}

/* ── HOW IT WORKS ── */
.hiw-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
  background:var(--border);border-radius:var(--r);overflow:hidden;
  margin-top:60px;
}
.hiw-card{
  background:var(--bg2);padding:40px 36px;
  position:relative;overflow:hidden;
  transition:background 0.3s;
}
.hiw-card::after{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg, var(--blue), #7B9FF9);
  transform:scaleX(0);transform-origin:left;
  transition:transform 0.4s ease;
}
.hiw-card:hover{background:rgba(59,99,247,0.05)}
.hiw-card:hover::after{transform:scaleX(1)}
.hiw-num{
  font-family:var(--font-display);
  font-size:80px;font-weight:400;
  line-height:1;margin-bottom:24px;
  color:rgba(59,99,247,0.15);letter-spacing:-3px;
}
.hiw-icon{
  width:52px;height:52px;border-radius:14px;
  background:rgba(59,99,247,0.12);
  border:1px solid rgba(59,99,247,0.2);
  display:flex;align-items:center;justify-content:center;
  font-size:24px;margin-bottom:20px;
}
.hiw-card h3{font-size:22px;font-weight:700;margin-bottom:12px;color:var(--white)}
.hiw-card p{font-size:15px;color:var(--text-muted);line-height:1.7}

/* ── TRACKER (animated) ── */
.tracker-section{
  background:linear-gradient(180deg, var(--bg2) 0%, #080B14 100%);
  padding:100px 0;overflow:hidden;
}
.tracker-inner{
  display:grid;grid-template-columns:1fr 1fr;
  gap:80px;align-items:center;
}
.tracker-card{
  background:rgba(255,255,255,0.03);
  border:1px solid var(--border-light);
  border-radius:var(--r);padding:32px;
  box-shadow:0 20px 60px rgba(0,0,0,0.4);
}
.tracker-title-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px}
.tracker-label{font-size:13px;font-weight:600;color:var(--white)}
.tracker-sub{font-size:12px;color:var(--text-dim);margin-top:2px}
.tracker-prop{
  font-size:11px;background:rgba(59,99,247,0.12);color:#7B9FF9;
  border-radius:6px;padding:4px 10px;font-weight:600;
}
.tracker-steps{display:flex;flex-direction:column;gap:0}
.t-step{
  display:flex;align-items:flex-start;gap:14px;padding:16px 0;
  border-bottom:1px solid var(--border);
  opacity:0.4;transition:opacity 0.5s;
}
.t-step:last-child{border:none}
.t-step.done{opacity:1}
.t-step.active{opacity:1}
.t-dot-wrap{display:flex;flex-direction:column;align-items:center;gap:0;padding-top:2px}
.t-dot{
  width:22px;height:22px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;font-size:11px;
  border:2px solid var(--border);
  background:transparent;color:var(--text-dim);
  transition:all 0.4s;
}
.t-step.done .t-dot{background:var(--green);border-color:var(--green);color:white}
.t-step.active .t-dot{
  background:var(--blue);border-color:var(--blue);color:white;
  box-shadow:0 0 16px rgba(59,99,247,0.5);
  animation:ping 1.5s ease-in-out infinite;
}
@keyframes ping{0%,100%{box-shadow:0 0 0 0 rgba(59,99,247,0.4)}50%{box-shadow:0 0 0 8px rgba(59,99,247,0)}}
.t-line{width:2px;flex:1;min-height:8px;background:var(--border);margin-top:2px}
.t-step.done .t-line{background:var(--green)}
.t-info{flex:1}
.t-name{font-size:14px;font-weight:600;color:var(--text-muted);transition:color 0.4s}
.t-step.done .t-name,.t-step.active .t-name{color:var(--white)}
.t-when{font-size:12px;color:var(--text-dim);margin-top:3px}
.t-step.active .t-when{color:var(--blue)}
.t-badge{
  font-size:11px;font-weight:600;padding:3px 9px;border-radius:100px;
  white-space:nowrap;align-self:center;
}
.badge-done{background:rgba(16,185,129,0.12);color:var(--green);border:1px solid rgba(16,185,129,0.2)}
.badge-active{background:rgba(59,99,247,0.12);color:#7B9FF9;border:1px solid rgba(59,99,247,0.2)}
.badge-pending{background:var(--surface);color:var(--text-dim);border:1px solid var(--border)}

/* ── FEATURES (light bg) ── */
.feat-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:24px;margin-top:60px;
}
.feat-card{
  border:1px solid #E5E7EB;border-radius:var(--r);
  padding:32px;background:white;
  transition:all 0.3s;cursor:default;
  position:relative;overflow:hidden;
}
.feat-card::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg, rgba(59,99,247,0.03) 0%, transparent 60%);
  opacity:0;transition:opacity 0.3s;
}
.feat-card:hover{border-color:#C7D4FE;box-shadow:0 16px 48px rgba(59,99,247,0.1);transform:translateY(-4px)}
.feat-card:hover::before{opacity:1}
.feat-icon{
  width:52px;height:52px;border-radius:14px;
  background:#EEF2FF;border:1px solid #C7D4FE;
  display:flex;align-items:center;justify-content:center;
  font-size:24px;margin-bottom:20px;
  transition:all 0.3s;
}
.feat-card:hover .feat-icon{background:var(--blue);border-color:var(--blue);transform:scale(1.1) rotate(-3deg)}
.feat-card h3{font-size:18px;font-weight:700;color:#0F1117;margin-bottom:10px;letter-spacing:-0.3px}
.feat-card p{font-size:14px;color:#6B7280;line-height:1.7}

/* ── STATS ── */
.stats-bar{
  background:var(--blue);padding:56px 0;
  position:relative;overflow:hidden;
}
.stats-bar::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 50%);
}
.stats-inner{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:0;position:relative;z-index:1;
}
.stat-item{
  text-align:center;padding:0 24px;
  border-right:1px solid rgba(255,255,255,0.15);
}
.stat-item:last-child{border:none}
.stat-n{
  font-family:var(--font-display);
  font-size:clamp(40px,5vw,60px);font-weight:400;
  color:white;letter-spacing:-2px;line-height:1;margin-bottom:8px;
}
.stat-n sup{font-size:0.5em;vertical-align:super}
.stat-l{font-size:15px;color:rgba(255,255,255,0.7);font-weight:400}

/* ── TESTIMONIALS ── */
.testi-scroll{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:24px;margin-top:60px;
}
.testi-card{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:var(--r);padding:28px;
  transition:all 0.3s;
}
.testi-card:hover{border-color:rgba(59,99,247,0.3);transform:translateY(-3px);box-shadow:0 20px 40px rgba(0,0,0,0.3)}
.stars{color:#F59E0B;font-size:13px;margin-bottom:16px;letter-spacing:2px}
.testi-q{font-size:15px;line-height:1.75;color:var(--text);margin-bottom:20px;font-style:italic}
.testi-author{display:flex;align-items:center;gap:12px}
.t-av{
  width:38px;height:38px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-weight:700;font-size:14px;color:white;flex-shrink:0;
}
.t-name{font-size:14px;font-weight:600;color:var(--white)}
.t-role{font-size:12px;color:var(--text-dim);margin-top:2px}

/* ── FAQ ── */
.faq-list{margin-top:50px;display:flex;flex-direction:column;gap:1px;background:var(--border);border-radius:var(--r);overflow:hidden}
.faq-item{background:var(--bg2)}
.faq-q{
  display:flex;align-items:center;justify-content:space-between;
  padding:22px 28px;cursor:pointer;
  font-size:16px;font-weight:600;color:var(--white);
  transition:color 0.2s;user-select:none;
}
.faq-q:hover{color:#7B9FF9}
.faq-arrow{
  width:24px;height:24px;border-radius:50%;
  background:var(--surface);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:14px;flex-shrink:0;transition:all 0.3s;
}
.faq-item.open .faq-arrow{background:rgba(59,99,247,0.15);border-color:rgba(59,99,247,0.3);transform:rotate(45deg);color:var(--blue)}
.faq-a{
  max-height:0;overflow:hidden;
  font-size:15px;color:var(--text-muted);line-height:1.7;
  transition:max-height 0.4s ease, padding 0.3s ease;
  padding:0 28px;
}
.faq-item.open .faq-a{max-height:200px;padding:0 28px 22px}

/* ── CTA FINAL ── */
.cta-final{
  background:linear-gradient(135deg, #0F1A4E 0%, #0C1235 50%, #061230 100%);
  padding:120px 0;text-align:center;overflow:hidden;position:relative;
}
.cta-final::before{
  content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  width:600px;height:600px;
  background:radial-gradient(circle, rgba(59,99,247,0.15) 0%, transparent 65%);
  pointer-events:none;
}
.cta-final h2{
  font-family:var(--font-display);
  font-size:clamp(38px,6vw,68px);font-weight:400;
  color:white;letter-spacing:-1.5px;margin-bottom:20px;
  position:relative;z-index:1;
}
.cta-final h2 em{font-style:italic;color:#7B9FF9}
.cta-final p{font-size:18px;color:rgba(255,255,255,0.55);margin-bottom:44px;position:relative;z-index:1}
.cta-form-wrap{display:flex;justify-content:center;gap:12px;flex-wrap:wrap;position:relative;z-index:1}
.cta-input{
  background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);
  border-radius:100px;padding:14px 26px;
  font-size:15px;color:white;font-family:var(--font-ui);
  outline:none;width:300px;
  transition:all 0.3s;
}
.cta-input::placeholder{color:rgba(255,255,255,0.3)}
.cta-input:focus{border-color:rgba(59,99,247,0.6);background:rgba(59,99,247,0.08)}
.cta-btn{
  background:var(--blue);color:white;border:none;
  border-radius:100px;padding:14px 32px;
  font-size:15px;font-weight:600;cursor:pointer;
  font-family:var(--font-ui);
  transition:all 0.2s;
  box-shadow:0 8px 30px rgba(59,99,247,0.4);
}
.cta-btn:hover{background:var(--blue-hover);transform:translateY(-2px);box-shadow:0 12px 40px rgba(59,99,247,0.5)}
.cta-btn.success{background:var(--green);box-shadow:0 8px 30px rgba(16,185,129,0.4)}
.cta-note{margin-top:18px;font-size:13px;color:rgba(255,255,255,0.3);position:relative;z-index:1}

/* ── FOOTER ── */
footer{
  background:var(--bg);border-top:1px solid var(--border);
  padding:64px clamp(20px,5%,80px) 32px;
}
.footer-top{
  display:grid;grid-template-columns:1.5fr repeat(3,1fr);
  gap:48px;margin-bottom:48px;
}
.footer-brand p{font-size:14px;color:var(--text-dim);margin-top:12px;line-height:1.7;max-width:200px}
.footer-col h5{font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-dim);margin-bottom:18px}
.footer-col a{display:block;font-size:14px;color:var(--text-muted);text-decoration:none;margin-bottom:12px;transition:color 0.2s}
.footer-col a:hover{color:var(--white)}
.footer-bottom{
  border-top:1px solid var(--border);padding-top:24px;
  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;
}
.footer-copy{font-size:13px;color:var(--text-dim)}

/* ── ANIMATIONS ── */
@keyframes fade-up{
  from{opacity:0;transform:translateY(24px)}
  to{opacity:1;transform:translateY(0)}
}
.reveal{opacity:0;transform:translateY(28px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal.visible{opacity:1;transform:none}
.reveal-left{opacity:0;transform:translateX(-30px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal-left.visible{opacity:1;transform:none}
.reveal-right{opacity:0;transform:translateX(30px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal-right.visible{opacity:1;transform:none}

/* ── COUNTER ── */
.counter-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.25);
  color:#10B981;border-radius:100px;padding:4px 14px;
  font-size:12px;font-weight:600;margin-bottom:12px;
}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .win-sidebar{display:none}
  .win-body{grid-template-columns:1fr}
  .hiw-grid{grid-template-columns:1fr}
  .feat-grid{grid-template-columns:repeat(2,1fr)}
